# Copier ce fichier en settings.yaml et remplir les valeurs
# Ne jamais commiter settings.yaml (il est dans .gitignore)

mistral:
  api_key: "votre_cle_api_mistral"     # console.mistral.ai → API Keys
  model: "mistral-small-latest"        # Gratuit sur le free tier

email:
  smtp_host: "smtp.gmail.com"
  smtp_port: 587
  smtp_user: "votre.adresse@gmail.com"      # Ton adresse Gmail
  smtp_password: "xxxx xxxx xxxx xxxx"      # Mot de passe d'application Gmail (16 caractères)
  sender_address: "votre.adresse@gmail.com"
  sender_name: "Des nouvelles des étoiles"
  recipient: "votre.adresse@gmail.com"      # Peut être la même adresse

digest:
  # Nombre max d'articles à traiter par exécution (évite les coûts excessifs)
  max_articles: 20
  # Nombre de jours en arrière pour considérer un article comme "récent"
  lookback_days: 2
  # Langue de la synthèse générée
  language: "fr"
